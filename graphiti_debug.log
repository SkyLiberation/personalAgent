DEBUG:neo4j.io:[#6E9F]  C: RUN '\n                UNWIND $episodes AS episode\n                MERGE (n:Episodic {uuid: episode.uuid})\n                SET n = {uuid: episode.uuid, name: episode.name, group_id: episode.group_id, source_description: episode.source_description, source: episode.source, content: episode.content, \n                entity_edges: episode.entity_edges, created_at: episode.created_at, valid_at: episode.valid_at}\n                RETURN n.uuid AS uuid\n            ' {'episodes': [{'uuid': '580a36a1-71bc-4f88-8986-cc55e153a14b', 'name': '在支付系统重构项目里，Alice 提出把订单服务...', 'group_id': 'personal-agent-default', 'created_at': datetime.datetime(2026, 5, 8, 2, 43, 31, 51720, tzinfo=datetime.timezone.utc), 'source': 'text', 'source_description': 'Personal note f168f159-69f5-4b06-a132-622b394ca51b', 'content': '在支付系统重构项目里，Alice 提出把订单服务和库存服务解耦。她认为服务降级可以保护核心下单链路，但推荐模块会干扰支付流程。第一阶段方案包括 Redis 限流、熔断器和异步消息队列。', 'valid_at': datetime.datetime(2026, 5, 8, 2, 43, 9, 628974), 'entity_edges': ['35611cdb-e5bf-4cad-9996-acbedb45cc6f', '16deac6c-89f0-490e-8633-c4868d9be3fe', 'd05a8820-e8b7-42ed-92ce-a16ed5c97ccb', '7ab3d6ee-6bd2-4212-b453-a494c5214799', '9370b21c-dafd-456d-a2dd-f0f0c8b445dc', 'de85f518-4f55-4cb1-8bc4-d29ea025bc31'], 'episode_metadata': None}]} {}
